FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ID=
FEISHU_LOG_TABLE_ID=
IFIND_ACCESS_TOKEN=
IFIND_REFRESH_TOKEN=
YFINANCE_CACHE_DIR=

# LLM providers
VOLCENGINE_ENABLED=true
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=deepseek-r1-250528
SILICONFLOW_ENABLED=true
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2

# HK financial sync
HK_LLM_TIMEOUT_SECONDS=120
HK_LLM_MAX_RETRIES=5
HK_LLM_BACKOFF_BASE_SECONDS=1
HK_STOCK_POOL_EXCEL=data/hk_stock_pool.xlsx
HK_STOCK_POOL_CODE_COLUMN=code
FINANCIAL_SYNC_WORKERS=4
HK_SYNC_WORKERS=2
NON_HK_SYNC_WORKERS=4

# Optional local webhook bridge.
# Not required when Feishu calls GitHub repository_dispatch directly.
GITHUB_DISPATCH_TOKEN=
GITHUB_REPOSITORY_OWNER=
GITHUB_REPOSITORY_NAME=
GITHUB_DISPATCH_EVENT_TYPE=watchlist_price_init
WEBHOOK_SHARED_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8787
